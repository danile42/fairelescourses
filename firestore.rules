rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Shops (top-level, shared across households) ───────────────────────────
    // Any authenticated user can read shops (for search/import).
    // Only the ownerUid may update or delete a shop.
    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      // Owner can always update/delete.  Any authenticated user may also
      // update a household shop provided the householdHash is unchanged
      // (i.e. they know the household secret and are keeping the shop in
      // the same household).  Deleting is likewise open to any household
      // member — the householdHash can only be verified on update, so we
      // allow delete for any authenticated user that can read the doc.
      allow update: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                        || (resource.data.householdHash != null
                            && request.resource.data.householdHash
                               == resource.data.householdHash));
      allow delete: if request.auth != null
                    && (resource.data.ownerUid == request.auth.uid
                        || resource.data.householdHash != null);
    }

    // ── Public Shops (shared OSM templates) ──────────────────────────────────
    // Any authenticated user can read public shops and their versions.
    match /public_shops/{osmId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /versions/{versionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    // ── Household-scoped data ─────────────────────────────────────────────────
    // The document ID is SHA-256(householdId), so only users who know the
    // household ID can construct the correct path.
    match /h/{householdHash} {

      // Shopping lists (encrypted blobs)
      match /l/{listId} {
        allow read, write: if request.auth != null;
      }

      // Collaborative navigation session
      match /nav/{docId} {
        allow read, write: if request.auth != null;
      }

      // Lightweight household activity events for notifications.
      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.keys().hasAll([
                           'type',
                           'listId',
                           'actorUid',
                           'createdAt'
                         ])
                      && request.resource.data.keys().hasOnly([
                           'type',
                           'listId',
                           'actorUid',
                           'createdAt',
                           'itemCount'
                         ])
                      && request.resource.data.type in [
                           'list_item_added',
                           'list_updated',
                           'tour_finished'
                         ]
                      && request.resource.data.listId is string
                      && request.resource.data.listId.size() > 0
                      && request.resource.data.listId.size() <= 128
                      && request.resource.data.actorUid == request.auth.uid
                      && request.resource.data.createdAt == request.time
                      && (!('itemCount' in request.resource.data)
                          || (request.resource.data.itemCount is int
                              && request.resource.data.itemCount >= 1
                              && request.resource.data.itemCount <= 200));
        allow update, delete: if false;
      }
    }
  }
}
